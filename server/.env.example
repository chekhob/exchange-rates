# Exchange Rates Backend Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# ExchangeRate-API Configuration (Primary)
# Get a free API key from: https://www.exchangerate-api.com
EXCHANGERATE_API_KEY=your_api_key_here

# Frankfurter API Configuration (Fallback)
FRANKFURTER_API_BASE_URL=https://api.frankfurter.dev/v1

# Logging
LOG_LEVEL=info